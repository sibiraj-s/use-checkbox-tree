{
  "name": "use-checkbox-tree",
  "version": "0.2.0",
  "description": "React hook for checkbox tree component",
  "keywords": [
    "checkbox-tree",
    "react",
    "react-hooks"
  ],
  "homepage": "https://github.com/sibiraj-s/use-checkbox-tree#readme",
  "bugs": "https://github.com/sibiraj-s/use-checkbox-tree/issues",
  "license": "MIT",
  "author": "sibiraj-s",
  "repository": "github:sibiraj-s/use-checkbox-tree",
  "files": [
    "dist/"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "oxlint .",
    "test": "vitest --reporter verbose --coverage",
    "build": "tsdown",
    "prepare": "is-ci || husky install",
    "storybook": "storybook dev -p 6006 --disable-telemetry",
    "build:storybook": "storybook build --disable-telemetry",
    "prepublishOnly": "is-ci || publint"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@storybook/addon-links": "^10.3.0",
    "@storybook/react": "^10.3.0",
    "@storybook/react-vite": "^10.3.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "commitlint-config-non-conventional": "^1.0.1",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "publint": "^0.3.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.3.0",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  }
}
